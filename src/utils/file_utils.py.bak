#!/usr/bin/env python
# -*- coding: utf-8 -*-

"""
ж–Үд»¶ж“ҚдҪңе·Ҙе…·еҮҪж•°
"""

import os
import shutil
import zipfile
import tempfile
import logging
import re
from pathlib import Path
import time
import platform
import subprocess
import random

logger = logging.getLogger(__name__)

def ensure_dir(directory):
    """
    зЎ®дҝқзӣ®еҪ•еӯҳеңЁпјҢеҰӮжһңдёҚеӯҳеңЁеҲҷеҲӣе»ә
    
    Args:
        directory: зӣ®еҪ•и·Ҝеҫ„
    """
    if not os.path.exists(directory):
        os.makedirs(directory)
        logger.debug(f"еҲӣе»әзӣ®еҪ•: {directory}")

def copy_file(src, dst):
    """
    еӨҚеҲ¶ж–Үд»¶
    
    Args:
        src: жәҗж–Үд»¶и·Ҝеҫ„
        dst: зӣ®ж Үж–Үд»¶и·Ҝеҫ„
    
    Returns:
        bool: ж“ҚдҪңжҳҜеҗҰжҲҗеҠҹ
    """
    try:
        shutil.copy2(src, dst)
        logger.debug(f"еӨҚеҲ¶ж–Үд»¶: {src} -> {dst}")
        return True
    except Exception as e:
        logger.error(f"еӨҚеҲ¶ж–Үд»¶еӨұиҙҘ: {e}")
        return False

def delete_file(file_path):
    """
    еҲ йҷӨж–Үд»¶
    
    Args:
        file_path: ж–Үд»¶и·Ҝеҫ„
    
    Returns:
        bool: ж“ҚдҪңжҳҜеҗҰжҲҗеҠҹ
    """
    try:
        if os.path.exists(file_path):
            os.remove(file_path)
            logger.debug(f"еҲ йҷӨж–Үд»¶: {file_path}")
            return True
        return False
    except Exception as e:
        logger.error(f"еҲ йҷӨж–Үд»¶еӨұиҙҘ: {e}")
        return False

def sanitize_filename(filename):
    """
    жё…зҗҶж–Үд»¶еҗҚпјҢз§»йҷӨжҲ–жӣҝжҚўдёҚж”ҜжҢҒзҡ„еӯ—з¬Ұ
    
    Args:
        filename: еҺҹе§Ӣж–Үд»¶еҗҚ
    
    Returns:
        str: жё…зҗҶеҗҺзҡ„ж–Үд»¶еҗҚ
    """
    # еҰӮжһңж–Үд»¶еҗҚеҢ…еҗ«йқһASCIIеӯ—з¬ҰпјҢдҪҝз”ЁиӢұж–Үжӣҝд»Ј
    if any(ord(c) > 127 for c in filename):
        # дҝқз•ҷж–Үд»¶жү©еұ•еҗҚ
        name, ext = os.path.splitext(filename)
        # дҪҝз”Ёжӣҙе…·еҸҜиҜ»жҖ§зҡ„еҗҚз§°пјҢе№¶зЎ®дҝқе”ҜдёҖжҖ§
        import hashlib
        hash_obj = hashlib.md5(name.encode('utf-8'))
        hash_str = hash_obj.hexdigest()[:8]
        return f"app_{hash_str}{ext}"
    return filename

def sanitize_app_contents(app_path):
    """
    жё…зҗҶеә”з”ЁеҶ…йғЁзҡ„дёӯж–Үж–Үд»¶еҗҚпјҲдёҚеҶҚйҮҚе‘ҪеҗҚеҸҜжү§иЎҢж–Үд»¶пјҢдҝқз•ҷеҺҹе§ӢеҗҚпјү
    Args:
        app_path: еә”з”Ёзӣ®еҪ•и·Ҝеҫ„
    Returns:
        bool: ж“ҚдҪңжҳҜеҗҰжҲҗеҠҹ
    """
    try:
        # иҜ»еҸ–Info.plist
        info_plist_path = os.path.join(app_path, "Info.plist")
        if not os.path.exists(info_plist_path):
            logger.error(f"жүҫдёҚеҲ°Info.plistж–Үд»¶: {info_plist_path}")
            return False
        info_plist = read_plist(info_plist_path)
        if not info_plist:
            logger.error(f"иҜ»еҸ–Info.plistеӨұиҙҘ: {info_plist_path}")
            return False
        # иҺ·еҸ–еҸҜжү§иЎҢж–Үд»¶еҗҚпјҢзҰҒжӯўеҜ№е…¶йҮҚе‘ҪеҗҚ
        executable_name = info_plist.get("CFBundleExecutable", "")
        # еӨ„зҗҶе…¶д»–еҸҜиғҪеҢ…еҗ«дёӯж–Үзҡ„ж–Үд»¶пјҲжҺ’йҷӨеҸҜжү§иЎҢж–Үд»¶пјү
        for root, dirs, files in os.walk(app_path):
            for file in files:
                if file == executable_name:
                    continue  # и·іиҝҮеҸҜжү§иЎҢж–Үд»¶
                if any(ord(c) > 127 for c in file):
                    old_path = os.path.join(root, file)
                    new_file = sanitize_filename(file)
                    new_path = os.path.join(root, new_file)
                    os.rename(old_path, new_path)
                    logger.debug(f"йҮҚе‘ҪеҗҚж–Үд»¶: {file} -> {new_file}")
            for i, dir_name in enumerate(dirs):
                if any(ord(c) > 127 for c in dir_name):
                    old_path = os.path.join(root, dir_name)
                    new_dir = sanitize_filename(dir_name)
                    new_path = os.path.join(root, new_dir)
                    os.rename(old_path, new_path)
                    dirs[i] = new_dir  # жӣҙж–°зӣ®еҪ•еҲ—иЎЁпјҢд»Ҙдҫҝз»§з»ӯйҒҚеҺҶ
                    logger.debug(f"йҮҚе‘ҪеҗҚзӣ®еҪ•: {dir_name} -> {new_dir}")
        return True
    except Exception as e:
        logger.error(f"жё…зҗҶеә”з”ЁеҶ…йғЁдёӯж–Үж–Үд»¶еҗҚеӨұиҙҘ: {e}")
        return False

def extract_ipa(ipa_path, extract_dir=None):
    """
    и§ЈеҺӢIPAж–Үд»¶пјҢиҝ”еӣһи§ЈеҺӢзӣ®еҪ•е’ҢеҺҹе§Ӣ.appеҗҚз§°
    Returns:
        (extract_dir, original_app_name)
    """
    try:
        # еңЁеҪ“еүҚзӣ®еҪ•еҲӣе»әunzipзӣ®еҪ•
        current_dir = os.path.dirname(os.path.abspath(__file__))
        base_dir = os.path.dirname(os.path.dirname(current_dir))  # иҺ·еҸ–йЎ№зӣ®ж №зӣ®еҪ•
        unzip_dir = os.path.join(base_dir, "unzip")
        
        # зЎ®дҝқunzipзӣ®еҪ•еӯҳеңЁ
        if not os.path.exists(unzip_dir):
            os.makedirs(unzip_dir)
        
        # з”ҹжҲҗйҡҸжңә13дҪҚж•°еӯ—дҪңдёәи§ЈеҺӢзӣ®еҪ•еҗҚ
        random_id = ''.join(str(random.randint(0, 9)) for _ in range(13))
        extract_dir = os.path.join(unzip_dir, random_id)
        
        # зЎ®дҝқи§ЈеҺӢзӣ®еҪ•еӯҳеңЁ
        if not os.path.exists(extract_dir):
            os.makedirs(extract_dir)
        
        logger.info(f"ејҖе§Ӣи§ЈеҺӢIPAж–Үд»¶: {ipa_path} -> {extract_dir}")
        
        # дҪҝз”Ё7zе‘Ҫд»ӨиЎҢе·Ҙе…·и§ЈеҺӢпјҲеҰӮжһңеҸҜз”Ёпјү
        try:
            # жЈҖжҹҘ7zжҳҜеҗҰеҸҜз”Ё
            seven_zip_path = None
            if platform.system() == "Windows":
                # еңЁWindowsдёҠжҹҘжүҫ7z.exe
                possible_paths = [
                    r"C:\Program Files\7-Zip\7z.exe",
                    r"C:\Program Files (x86)\7-Zip\7z.exe"
                ]
                for path in possible_paths:
                    if os.path.exists(path):
                        seven_zip_path = path
                        break
            
            if seven_zip_path:
                # дҪҝз”Ё7zи§ЈеҺӢпјҢж·»еҠ йқҷй»ҳжЁЎејҸеҸӮж•°
                cmd = [seven_zip_path, "x", "-y", "-bso0", "-bsp0", f"-o{extract_dir}", ipa_path]
                
                # дҪҝз”Ёsubprocess.CREATE_NO_WINDOWж Үеҝ—йҡҗи—Ҹе‘Ҫд»ӨзӘ—еҸЈпјҲд»…еңЁWindowsдёҠпјү
                creation_flags = 0
                if platform.system() == "Windows":
                    creation_flags = 0x08000000  # CREATE_NO_WINDOW
                
                result = subprocess.run(cmd, 
                                      stdout=subprocess.PIPE, 
                                      stderr=subprocess.PIPE, 
                                      text=True,
                                      creationflags=creation_flags)
                
                if result.returncode == 0:
                    logger.info("дҪҝз”Ё7zжҲҗеҠҹи§ЈеҺӢIPAж–Үд»¶")
                else:
                    logger.warning(f"7zи§ЈеҺӢеӨұиҙҘ: {result.stderr}пјҢе°қиҜ•дҪҝз”Ёе…¶д»–ж–№жі•")
                    # еҰӮжһң7zи§ЈеҺӢеӨұиҙҘпјҢе°қиҜ•дҪҝз”Ёзі»з»ҹе‘Ҫд»Ө
                    _extract_with_system_commands(ipa_path, extract_dir)
            else:
                # еҰӮжһңжүҫдёҚеҲ°7zпјҢе°қиҜ•дҪҝз”Ёзі»з»ҹе‘Ҫд»Ө
                _extract_with_system_commands(ipa_path, extract_dir)
        except Exception as e:
            logger.warning(f"7zи§ЈеҺӢеҮәй”ҷ: {e}пјҢе°қиҜ•дҪҝз”Ёе…¶д»–ж–№жі•")
            # еҰӮжһңеҮәзҺ°ејӮеёёпјҢе°қиҜ•дҪҝз”Ёзі»з»ҹе‘Ҫд»Ө
            _extract_with_system_commands(ipa_path, extract_dir)
        
        logger.info(f"IPAж–Үд»¶и§ЈеҺӢе®ҢжҲҗ: {ipa_path} -> {extract_dir}")
        
        # иҺ·еҸ–еҺҹе§Ӣеә”з”ЁеҗҚз§°
        original_app_name = None
        payload_dir = os.path.join(extract_dir, "Payload")
        if os.path.exists(payload_dir):
            for item in os.listdir(payload_dir):
                item_path = os.path.join(payload_dir, item)
                if os.path.isdir(item_path):
                    if item.endswith(".app"):
                        original_app_name = item
                        logger.info(f"жүҫеҲ°еҺҹе§Ӣеә”з”ЁеҗҚз§°: {original_app_name}")
                        break
                    else:
                        original_app_name = item
                        logger.info(f"жүҫеҲ°еҸҜиғҪзҡ„еҺҹе§Ӣеә”з”ЁеҗҚз§°: {original_app_name}")
        
        # иҺ·еҸ–еә”з”Ёи·Ҝеҫ„
        app_path = get_app_path_in_ipa(extract_dir)
        if app_path:
            logger.info(f"жүҫеҲ°еә”з”Ёи·Ҝеҫ„: {app_path}")
            sanitize_app_contents(app_path)
        else:
            logger.warning("жңӘжүҫеҲ°.appзӣ®еҪ•пјҢе°қиҜ•жүӢеҠЁжҹҘжүҫе’ҢйҮҚе‘ҪеҗҚ")
            payload_dir = os.path.join(extract_dir, "Payload")
            if os.path.exists(payload_dir):
                for item in os.listdir(payload_dir):
                    item_path = os.path.join(payload_dir, item)
                    if os.path.isdir(item_path):
                        if not item.endswith(".app"):
                            new_name = f"app_{int(time.time())}.app"
                            new_path = os.path.join(payload_dir, new_name)
                            try:
                                os.rename(item_path, new_path)
                                logger.info(f"йҮҚе‘ҪеҗҚеҸҜиғҪзҡ„еә”з”Ёзӣ®еҪ•: {item} -> {new_name}")
                                app_path = get_app_path_in_ipa(extract_dir)
                                if app_path:
                                    sanitize_app_contents(app_path)
                                    break
                            except Exception as e:
                                logger.error(f"йҮҚе‘ҪеҗҚзӣ®еҪ•еӨұиҙҘ: {e}")
        
        return extract_dir, original_app_name
    except Exception as e:
        logger.error(f"и§ЈеҺӢIPAж–Үд»¶еӨұиҙҘ: {e}")
        return None, None

def _extract_with_system_commands(ipa_path, extract_dir):
    """дҪҝз”Ёзі»з»ҹе‘Ҫд»Өи§ЈеҺӢIPAж–Үд»¶"""
    try:
        # иҺ·еҸ–зі»з»ҹзұ»еһӢ
        system = platform.system()
        
        # еҲӣе»әйқҷй»ҳжЁЎејҸзҡ„subprocessеҸӮж•°
        creation_flags = 0
        if system == "Windows":
            creation_flags = 0x08000000  # CREATE_NO_WINDOW
        
        if system == "Windows":
            # дҪҝз”ЁPowerShellзҡ„Expand-Archiveе‘Ҫд»Ө
            ps_cmd = f'powershell -Command "Expand-Archive -Path \'{ipa_path}\' -DestinationPath \'{extract_dir}\' -Force"'
            result = subprocess.run(ps_cmd, 
                                  shell=True, 
                                  stdout=subprocess.PIPE, 
                                  stderr=subprocess.PIPE,
                                  creationflags=creation_flags)
            
            if result.returncode == 0:
                logger.info("дҪҝз”ЁPowerShellжҲҗеҠҹи§ЈеҺӢIPAж–Үд»¶")
                return True
            else:
                logger.warning(f"PowerShellи§ЈеҺӢеӨұиҙҘ: {result.stderr.decode('utf-8', errors='ignore')}")
        elif system in ["Darwin", "Linux"]:
            # дҪҝз”Ёunzipе‘Ҫд»Ө
            cmd = ["unzip", "-o", "-q", ipa_path, "-d", extract_dir]
            result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
            
            if result.returncode == 0:
                logger.info("дҪҝз”ЁunzipжҲҗеҠҹи§ЈеҺӢIPAж–Үд»¶")
                return True
            else:
                logger.warning(f"unzipи§ЈеҺӢеӨұиҙҘ: {result.stderr.decode('utf-8', errors='ignore')}")
        
        # еҰӮжһңзі»з»ҹе‘Ҫд»ӨеӨұиҙҘпјҢе°қиҜ•дҪҝз”ЁPythonзҡ„zipfileжЁЎеқ—
        logger.info("е°қиҜ•дҪҝз”ЁPythonзҡ„zipfileжЁЎеқ—и§ЈеҺӢ")
        _extract_with_zipfile(ipa_path, extract_dir)
        return True
    except Exception as e:
        logger.error(f"зі»з»ҹе‘Ҫд»Өи§ЈеҺӢеӨұиҙҘ: {e}")
        # е°қиҜ•дҪҝз”ЁPythonзҡ„zipfileжЁЎеқ—
        _extract_with_zipfile(ipa_path, extract_dir)
        return True

def _extract_with_zipfile(ipa_path, extract_dir):
    """
    дҪҝз”ЁPythonзҡ„zipfileжЁЎеқ—и§ЈеҺӢIPAж–Үд»¶
    
    Args:
        ipa_path: IPAж–Үд»¶и·Ҝеҫ„
        extract_dir: и§ЈеҺӢзӣ®еҪ•
    """
    try:
        with zipfile.ZipFile(ipa_path, 'r') as zip_ref:
            # е°қиҜ•дёҚеҗҢзҡ„зј–з Ғж–№ејҸ
            encodings = ['utf-8', 'gbk', 'gb2312', 'gb18030', 'big5']
            
            for file_info in zip_ref.infolist():
                for encoding in encodings:
                    try:
                        # е°қиҜ•дҪҝз”ЁдёҚеҗҢзј–з Ғи§Јз Ғж–Үд»¶еҗҚ
                        try:
                            # zipfileеңЁPython 3.6+дёӯж”ҜжҢҒPathеҜ№иұЎ
                            file_path = file_info.filename
                            # е°қиҜ•и§Јз Ғж–Үд»¶еҗҚ
                            if hasattr(file_path, 'decode'):
                                file_path = file_path.decode(encoding)
                        except (UnicodeDecodeError, AttributeError):
                            # еҰӮжһңи§Јз ҒеӨұиҙҘпјҢе°қиҜ•дёӢдёҖдёӘзј–з Ғ
                            continue
                        
                        target_path = os.path.join(extract_dir, file_path)
                        
                        # зЎ®дҝқзӣ®ж Үзӣ®еҪ•еӯҳеңЁ
                        target_dir = os.path.dirname(target_path)
                        if not os.path.exists(target_dir):
                            os.makedirs(target_dir, exist_ok=True)
                        
                        # жҸҗеҸ–ж–Үд»¶
                        with zip_ref.open(file_info) as source, open(target_path, "wb") as target:
                            shutil.copyfileobj(source, target)
                        
                        # еҰӮжһңжҲҗеҠҹжҸҗеҸ–пјҢи·іеҮәзј–з ҒеҫӘзҺҜ
                        break
                    except Exception as e:
                        # еҰӮжһңжҳҜжңҖеҗҺдёҖдёӘзј–з Ғе°қиҜ•пјҢи®°еҪ•й”ҷиҜҜ
                        if encoding == encodings[-1]:
                            logger.warning(f"ж— жі•жҸҗеҸ–ж–Үд»¶ {file_info.filename}: {e}")
        
        logger.debug("дҪҝз”ЁPython zipfileжЁЎеқ—и§ЈеҺӢе®ҢжҲҗ")
    except Exception as e:
        logger.error(f"дҪҝз”Ёzipfileи§ЈеҺӢеӨұиҙҘ: {e}")
        raise

def create_ipa(app_dir, output_path):
    """
    еҲӣе»әIPAж–Үд»¶
    
    Args:
        app_dir: еә”з”Ёзӣ®еҪ•и·Ҝеҫ„
        output_path: иҫ“еҮәIPAж–Үд»¶и·Ҝеҫ„
    
    Returns:
        bool: ж“ҚдҪңжҳҜеҗҰжҲҗеҠҹ
    """
    try:
        # еҲӣе»әдёҙж—¶зӣ®еҪ•з»“жһ„
        temp_dir = tempfile.mkdtemp(prefix="ipa_create_")
        payload_dir = os.path.join(temp_dir, "Payload")
        os.makedirs(payload_dir)
        
        # еӨҚеҲ¶еә”з”ЁеҲ°Payloadзӣ®еҪ• - дёҚеҶҚйҮҚе‘ҪеҗҚдёӯж–Үеә”з”Ёзӣ®еҪ•
        app_name = os.path.basename(app_dir)
        target_app_dir = os.path.join(payload_dir, app_name)
        
        # зӣҙжҺҘеӨҚеҲ¶пјҢдёҚеҶҚжЈҖжҹҘе’ҢйҮҚе‘ҪеҗҚдёӯж–ҮеҗҚз§°
        logger.debug(f"еӨҚеҲ¶еә”з”Ёзӣ®еҪ•: {app_dir} -> {target_app_dir}")
        shutil.copytree(app_dir, target_app_dir)
        
        # еҲӣе»әZIPж–Үд»¶
        with zipfile.ZipFile(output_path, 'w', zipfile.ZIP_DEFLATED) as zipf:
            for root, _, files in os.walk(temp_dir):
                for file in files:
                    file_path = os.path.join(root, file)
                    arcname = os.path.relpath(file_path, temp_dir)
                    zipf.write(file_path, arcname)
        
        # жё…зҗҶдёҙж—¶зӣ®еҪ•
        shutil.rmtree(temp_dir)
        
        logger.debug(f"еҲӣе»әIPAж–Үд»¶: {app_dir} -> {output_path}")
        return True
    except Exception as e:
        logger.error(f"еҲӣе»әIPAж–Үд»¶еӨұиҙҘ: {e}")
        return False

def get_app_path_in_ipa(extract_dir):
    """
    иҺ·еҸ–и§ЈеҺӢеҗҺзҡ„IPAдёӯзҡ„.appи·Ҝеҫ„
    
    Args:
        extract_dir: IPAи§ЈеҺӢзӣ®еҪ•
    
    Returns:
        str: .appи·Ҝеҫ„пјҢеҰӮжһңжңӘжүҫеҲ°еҲҷиҝ”еӣһNone
    """
    try:
        payload_dir = os.path.join(extract_dir, "Payload")
        if not os.path.exists(payload_dir):
            logger.error(f"ж— ж•Ҳзҡ„IPAз»“жһ„: жңӘжүҫеҲ°Payloadзӣ®еҪ•")
            return None
        
        # жҹҘжүҫ.appзӣ®еҪ•
        for item in os.listdir(payload_dir):
            if item.endswith(".app") and os.path.isdir(os.path.join(payload_dir, item)):
                return os.path.join(payload_dir, item)
        
        logger.error(f"ж— ж•Ҳзҡ„IPAз»“жһ„: жңӘжүҫеҲ°.appзӣ®еҪ•")
        return None
    except Exception as e:
        logger.error(f"иҺ·еҸ–.appи·Ҝеҫ„еӨұиҙҘ: {e}")
        return None

def read_plist(plist_path):
    """
    иҜ»еҸ–plistж–Үд»¶
    
    Args:
        plist_path: plistж–Үд»¶и·Ҝеҫ„
    
    Returns:
        dict: plistеҶ…е®№пјҢеҰӮжһңеӨұиҙҘеҲҷиҝ”еӣһNone
    """
    try:
        # йҰ–е…Ҳе°қиҜ•дҪҝз”ЁеҺҹз”ҹplistlib
        try:
            import plistlib
            with open(plist_path, 'rb') as fp:
                return plistlib.load(fp)
        except Exception as e1:
            logger.warning(f"дҪҝз”ЁеҺҹз”ҹplistlibиҜ»еҸ–еӨұиҙҘ: {e1}")
            
            # е°қиҜ•дҪҝз”ЁbiplistдҪңдёәеӨҮйҖү
            try:
                from biplist import readPlist
                return readPlist(plist_path)
            except Exception as e2:
                logger.warning(f"дҪҝз”ЁbiplistиҜ»еҸ–еӨұиҙҘ: {e2}")
                
                # жңҖеҗҺе°қиҜ•дҪҝз”Ёз¬¬дёүз§Қж–№жі•
                try:
                    import subprocess
                    import json
                    import tempfile
                    
                    # дҪҝз”ЁplutilиҪ¬жҚўдёәJSONпјҲд»…еңЁmacOSдёҠеҸҜз”Ёпјү
                    if platform.system() == "Darwin":
                        temp_json = tempfile.mktemp(suffix=".json")
                        subprocess.run(["plutil", "-convert", "json", "-o", temp_json, plist_path], check=True)
                        with open(temp_json, 'r', encoding='utf-8') as f:
                            data = json.load(f)
                        os.unlink(temp_json)
                        return data
                except Exception as e3:
                    logger.error(f"жүҖжңүиҜ»еҸ–plistж–№жі•йғҪеӨұиҙҘ: {e3}")
                    return None
    except Exception as e:
        logger.error(f"иҜ»еҸ–plistж–Үд»¶еӨұиҙҘ: {e}")
        return None

def write_plist(plist_path, data):
    """
    еҶҷе…Ҙplistж–Үд»¶
    
    Args:
        plist_path: plistж–Үд»¶и·Ҝеҫ„
        data: иҰҒеҶҷе…Ҙзҡ„ж•°жҚ®
    
    Returns:
        bool: ж“ҚдҪңжҳҜеҗҰжҲҗеҠҹ
    """
    try:
        # йҰ–е…Ҳе°қиҜ•дҪҝз”ЁеҺҹз”ҹplistlib
        try:
            import plistlib
            with open(plist_path, 'wb') as fp:
                plistlib.dump(data, fp)
            logger.debug(f"дҪҝз”ЁеҺҹз”ҹplistlibеҶҷе…Ҙplistж–Үд»¶: {plist_path}")
            return True
        except Exception as e1:
            logger.warning(f"дҪҝз”ЁеҺҹз”ҹplistlibеҶҷе…ҘеӨұиҙҘ: {e1}")
            
            # е°қиҜ•дҪҝз”ЁbiplistдҪңдёәеӨҮйҖү
            try:
                from biplist import writePlist
                writePlist(data, plist_path)
                logger.debug(f"дҪҝз”ЁbiplistеҶҷе…Ҙplistж–Үд»¶: {plist_path}")
                return True
            except Exception as e2:
                logger.error(f"жүҖжңүеҶҷе…Ҙplistж–№жі•йғҪеӨұиҙҘ: {e2}")
                return False
    except Exception as e:
        logger.error(f"еҶҷе…Ҙplistж–Үд»¶еӨұиҙҘ: {e}")
        return False

def get_file_size(file_path):
    """
    иҺ·еҸ–ж–Үд»¶еӨ§е°Ҹ
    
    Args:
        file_path: ж–Үд»¶и·Ҝеҫ„
    
    Returns:
        int: ж–Үд»¶еӨ§е°Ҹ(еӯ—иҠӮ)
    """
    try:
        return os.path.getsize(file_path)
    except Exception as e:
        logger.error(f"иҺ·еҸ–ж–Үд»¶еӨ§е°ҸеӨұиҙҘ: {e}")
        return 0

def get_file_md5(file_path):
    """
    иҺ·еҸ–ж–Үд»¶MD5еҖј
    
    Args:
        file_path: ж–Үд»¶и·Ҝеҫ„
    
    Returns:
        str: MD5еҖјпјҢеҰӮжһңеӨұиҙҘеҲҷиҝ”еӣһNone
    """
    try:
        import hashlib
        hash_md5 = hashlib.md5()
        with open(file_path, "rb") as f:
            for chunk in iter(lambda: f.read(4096), b""):
                hash_md5.update(chunk)
        return hash_md5.hexdigest()
    except Exception as e:
        logger.error(f"иҺ·еҸ–ж–Үд»¶MD5еҖјеӨұиҙҘ: {e}")
        return None

def restore_original_app_name(extract_dir, output_ipa_path, original_app_name):
    """
    жҒўеӨҚеҺҹе§Ӣзҡ„еә”з”ЁеҗҚз§°
    Args:
        extract_dir: и§ЈеҺӢзӣ®еҪ•и·Ҝеҫ„
        output_ipa_path: иҫ“еҮәзҡ„IPAж–Үд»¶и·Ҝеҫ„
        original_app_name: еҺҹе§Ӣ.appзӣ®еҪ•еҗҚ
    Returns:
        str: жҒўеӨҚеҺҹе§ӢеҗҚз§°еҗҺзҡ„IPAж–Үд»¶и·Ҝеҫ„
    """
    try:
        if not original_app_name:
            logger.warning("еҺҹе§Ӣеә”з”ЁеҗҚз§°дёәз©әпјҢж— жі•жҒўеӨҚ")
            return output_ipa_path
        logger.info(f"еҮҶеӨҮжҒўеӨҚеҺҹе§Ӣеә”з”ЁеҗҚз§°: {original_app_name}")
        temp_dir = tempfile.mkdtemp(prefix="restore_app_name_")
        with zipfile.ZipFile(output_ipa_path, 'r') as zip_ref:
            zip_ref.extractall(temp_dir)
        payload_dir = os.path.join(temp_dir, "Payload")
        current_app_path = None
        current_app_name = None
        if os.path.exists(payload_dir):
            for item in os.listdir(payload_dir):
                item_path = os.path.join(payload_dir, item)
                if os.path.isdir(item_path) and item.endswith(".app"):
                    current_app_path = item_path
                    current_app_name = item
                    break
        if not current_app_path or not current_app_name:
            logger.warning("жүҫдёҚеҲ°еҪ“еүҚеә”з”Ёзӣ®еҪ•пјҢж— жі•жҒўеӨҚеҺҹе§ӢеҗҚз§°")
            shutil.rmtree(temp_dir)
            return output_ipa_path
        if current_app_name != original_app_name:
            new_app_path = os.path.join(payload_dir, original_app_name)
            try:
                os.rename(current_app_path, new_app_path)
                logger.info(f"йҮҚе‘ҪеҗҚеә”з”Ёзӣ®еҪ•: {current_app_name} -> {original_app_name}")
            except Exception as e:
                logger.error(f"йҮҚе‘ҪеҗҚеә”з”Ёзӣ®еҪ•еӨұиҙҘ: {e}")
                shutil.rmtree(temp_dir)
                return output_ipa_path
        output_dir = os.path.dirname(output_ipa_path)
        filename = os.path.basename(output_ipa_path)
        name, ext = os.path.splitext(filename)
        restored_ipa_path = os.path.join(output_dir, f"{name}_restored{ext}")
        with zipfile.ZipFile(restored_ipa_path, 'w', zipfile.ZIP_DEFLATED) as zipf:
            for root, _, files in os.walk(temp_dir):
                for file in files:
                    file_path = os.path.join(root, file)
                    arcname = os.path.relpath(file_path, temp_dir)
                    zipf.write(file_path, arcname)
        logger.info(f"еҲӣе»әжҒўеӨҚеҺҹе§ӢеҗҚз§°зҡ„IPAж–Үд»¶: {restored_ipa_path}")
        shutil.rmtree(temp_dir)
        try:
            os.remove(output_ipa_path)
            logger.debug(f"еҲ йҷӨеҺҹе§ӢзӯҫеҗҚж–Үд»¶: {output_ipa_path}")
        except Exception as e:
            logger.warning(f"еҲ йҷӨеҺҹе§ӢзӯҫеҗҚж–Үд»¶еӨұиҙҘ: {e}")
        return restored_ipa_path
    except Exception as e:
        logger.error(f"жҒўеӨҚеҺҹе§Ӣеә”з”ЁеҗҚз§°еӨұиҙҘ: {e}")
        return output_ipa_path

def get_app_dylibs(app_path):
    """
    иҺ·еҸ–еә”з”Ёзҡ„еҠЁжҖҒеә“еҲ—иЎЁ
    
    Args:
        app_path: еә”з”Ёзӣ®еҪ•и·Ҝеҫ„
    
    Returns:
        list: еҠЁжҖҒеә“еҲ—иЎЁпјҢеҢ…еҗ«еҗҚз§°е’Ңи·Ҝеҫ„
    """
    dylibs = []
    try:
        # жЈҖжҹҘеә”з”Ёзӣ®еҪ•жҳҜеҗҰеӯҳеңЁ
        if not os.path.exists(app_path) or not os.path.isdir(app_path):
            logger.error(f"еә”з”Ёзӣ®еҪ•дёҚеӯҳеңЁ: {app_path}")
            return dylibs
        
        # иҺ·еҸ–еҸҜжү§иЎҢж–Үд»¶и·Ҝеҫ„
        info_plist_path = os.path.join(app_path, "Info.plist")
        if not os.path.exists(info_plist_path):
            logger.error(f"жүҫдёҚеҲ°Info.plistж–Үд»¶: {info_plist_path}")
            return dylibs
        
        info_plist = read_plist(info_plist_path)
        if not info_plist:
            logger.error(f"иҜ»еҸ–Info.plistеӨұиҙҘ: {info_plist_path}")
            return dylibs
        
        executable_name = info_plist.get("CFBundleExecutable", "")
        if not executable_name:
            logger.error("ж— жі•иҺ·еҸ–еҸҜжү§иЎҢж–Үд»¶еҗҚз§°")
            return dylibs
        
        executable_path = os.path.join(app_path, executable_name)
        if not os.path.exists(executable_path):
            logger.error(f"еҸҜжү§иЎҢж–Үд»¶дёҚеӯҳеңЁ: {executable_path}")
            return dylibs
        
        # еңЁmacOSдёҠдҪҝз”Ёotoolе‘Ҫд»ӨиҺ·еҸ–еҠЁжҖҒеә“еҲ—иЎЁ
        if platform.system() == "Darwin":
            try:
                result = subprocess.run(["otool", "-L", executable_path], 
                                      stdout=subprocess.PIPE, 
                                      stderr=subprocess.PIPE, 
                                      text=True)
                
                if result.returncode == 0:
                    lines = result.stdout.strip().split('\n')
                    # и·іиҝҮз¬¬дёҖиЎҢпјҲеҸҜжү§иЎҢж–Үд»¶и·Ҝеҫ„пјү
                    for line in lines[1:]:
                        line = line.strip()
                        if line:
                            # жҸҗеҸ–еҠЁжҖҒеә“и·Ҝеҫ„
                            parts = line.split('(')
                            if parts:
                                dylib_path = parts[0].strip()
                                dylib_name = os.path.basename(dylib_path)
                                
                                # иҺ·еҸ–еҠЁжҖҒеә“зұ»еһӢ
                                dylib_type = "зі»з»ҹ"
                                if "framework" in dylib_path.lower():
                                    dylib_type = "жЎҶжһ¶"
                                elif not (dylib_path.startswith("/System/") or dylib_path.startswith("/usr/lib/")):
                                    dylib_type = "иҮӘе®ҡд№ү"
                                
                                dylibs.append({
                                    "name": dylib_name,
                                    "path": dylib_path,
                                    "type": dylib_type,
                                    "location": "й“ҫжҺҘ"
                                })
            except Exception as e:
                logger.error(f"дҪҝз”ЁotoolиҺ·еҸ–еҠЁжҖҒеә“еҲ—иЎЁеӨұиҙҘ: {e}")
        
        # жҹҘжүҫFrameworksзӣ®еҪ•дёӯзҡ„еҠЁжҖҒеә“
        frameworks_dir = os.path.join(app_path, "Frameworks")
        if os.path.exists(frameworks_dir) and os.path.isdir(frameworks_dir):
            for item in os.listdir(frameworks_dir):
                if item.endswith(".dylib") or item.endswith(".framework"):
                    dylib_path = os.path.join(frameworks_dir, item)
                    
                    # еҲӨж–ӯеҠЁжҖҒеә“зұ»еһӢ
                    dylib_type = "иҮӘе®ҡд№ү"
                    if item.endswith(".framework"):
                        dylib_type = "жЎҶжһ¶"
                    
                    # иҺ·еҸ–ж–Үд»¶еӨ§е°Ҹ
                    file_size = 0
                    try:
                        file_size = os.path.getsize(dylib_path)
                    except:
                        pass
                    
                    # ж јејҸеҢ–ж–Үд»¶еӨ§е°Ҹ
                    size_str = ""
                    if file_size > 0:
                        if file_size < 1024:
                            size_str = f"{file_size} B"
                        elif file_size < 1024 * 1024:
                            size_str = f"{file_size / 1024:.1f} KB"
                        else:
                            size_str = f"{file_size / (1024 * 1024):.1f} MB"
                    
                    dylibs.append({
                        "name": item,
                        "path": dylib_path,
                        "type": dylib_type,
                        "location": "Frameworks",
                        "size": size_str
                    })
        
        # жҹҘжүҫеҸҜжү§иЎҢж–Үд»¶зӣ®еҪ•дёӯзҡ„еҠЁжҖҒеә“
        for item in os.listdir(app_path):
            if item.endswith(".dylib"):
                dylib_path = os.path.join(app_path, item)
                
                # иҺ·еҸ–ж–Үд»¶еӨ§е°Ҹ
                file_size = 0
                try:
                    file_size = os.path.getsize(dylib_path)
                except:
                    pass
                
                # ж јејҸеҢ–ж–Үд»¶еӨ§е°Ҹ
                size_str = ""
                if file_size > 0:
                    if file_size < 1024:
                        size_str = f"{file_size} B"
                    elif file_size < 1024 * 1024:
                        size_str = f"{file_size / 1024:.1f} KB"
                    else:
                        size_str = f"{file_size / (1024 * 1024):.1f} MB"
                
                dylibs.append({
                    "name": item,
                    "path": dylib_path,
                    "type": "иҮӘе®ҡд№ү",
                    "location": "ж №зӣ®еҪ•",
                    "size": size_str
                })
        
        logger.info(f"жүҫеҲ° {len(dylibs)} дёӘеҠЁжҖҒеә“")
        return dylibs
    except Exception as e:
        logger.error(f"иҺ·еҸ–еҠЁжҖҒеә“еҲ—иЎЁеӨұиҙҘ: {e}")
        return dylibs

def update_app_info(app_path, bundle_id=None, display_name=None, bundle_name=None, version_code=None, version_name=None):
    """
    жү№йҮҸжӣҙж–°Info.plistзҡ„е…ій”®дҝЎжҒҜ
    Args:
        app_path: .appзӣ®еҪ•и·Ҝеҫ„
        bundle_id: CFBundleIdentifier
        display_name: CFBundleDisplayName
        bundle_name: CFBundleName
        version_code: CFBundleVersion
        version_name: CFBundleShortVersionString
    Returns:
        bool: ж“ҚдҪңжҳҜеҗҰжҲҗеҠҹ
    """
    try:
        info_plist_path = os.path.join(app_path, "Info.plist")
        info = read_plist(info_plist_path)
        if not info:
            logger.error(f"иҜ»еҸ–Info.plistеӨұиҙҘ: {info_plist_path}")
            return False
        if bundle_id:
            info["CFBundleIdentifier"] = bundle_id
        if display_name is not None:
            if display_name.strip():
                info["CFBundleDisplayName"] = display_name
            elif "CFBundleDisplayName" in info:
                del info["CFBundleDisplayName"]
        if bundle_name:
            info["CFBundleName"] = bundle_name
        if version_code:
            info["CFBundleVersion"] = version_code
        if version_name:
            info["CFBundleShortVersionString"] = version_name
        write_plist(info_plist_path, info)
        logger.info(f"е·Іжӣҙж–°Info.plist: {info_plist_path}пјҢеҶ…е®№пјҡ{info}")
        return True
    except Exception as e:
        logger.error(f"жӣҙж–°Info.plistеӨұиҙҘ: {e}")
        return False 